static int ExtractOneSecond16k(const int16_t *pcm,
                               int pcm_count,
                               int16_t *out16k,
                               int max_out)
{
    int out_count = 0;

    /*
     * Skip the first 0.5 seconds of the recording to avoid startup artifacts.
     * At 96 kHz, 0.5 seconds = 48000 samples.
     */
    int start = 48000;

    if (pcm_count < start + 96000)
    {
        xil_printf("\r\nNot enough PCM samples for 1 second extraction\r\n");
        return 0;
    }

    /*
     * Convert 96 kHz to 16 kHz by taking every 6th sample.
     * This is a simple first prototype.
     */
    for (int i = start; i < start + 96000 && out_count < max_out; i += 6)
    {
        out16k[out_count++] = pcm[i];
    }

    return out_count;
}

