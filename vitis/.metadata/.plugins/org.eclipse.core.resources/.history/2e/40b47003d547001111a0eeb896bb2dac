static int32_t SignExtend24(u32 raw)
{
    int32_t sample = raw & 0x00FFFFFF;

    if (sample & 0x00800000)
    {
        sample |= 0xFF000000;
    }

    return sample;
}

static void PrintShiftDiagnostics(void)
{
    u32 *audio = (u32 *) MEM_BASE_ADDR;
    int num_words = (5 * NR_AUDIO_SAMPLES) / 4;

    xil_printf("\r\nShift diagnostics:\r\n");

    for (int mode = 0; mode < 4; mode++)
    {
        int min_val = 32767;
        int max_val = -32768;
        long long sum_abs = 0;

        for (int i = 0; i < num_words; i++)
        {
            u32 raw = audio[i];
            int16_t sample;

            if (mode == 0)
            {
                sample = (int16_t)(raw);
            }
            else if (mode == 1)
            {
                sample = (int16_t)(raw >> 8);
            }
            else if (mode == 2)
            {
                sample = (int16_t)(raw >> 16);
            }
            else
            {
                int32_t sample24 = ((int32_t)raw) >> 8;
                sample = (int16_t)(sample24 >> 8);
            }

            if (sample < min_val) min_val = sample;
            if (sample > max_val) max_val = sample;

            int v = sample;
            if (v < 0) v = -v;
            sum_abs += v;
        }

        xil_printf("mode %d: min=%d max=%d avg_abs=%d\r\n",
                   mode,
                   min_val,
                   max_val,
                   (int)(sum_abs / num_words));
    }
}

