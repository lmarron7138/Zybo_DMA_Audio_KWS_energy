static void PrintAudioStats(void)
{
    u32 *audio = (u32 *) MEM_BASE_ADDR;
    int num_words = (5 * NR_AUDIO_SAMPLES) / 4;

    int min_val = 32767;
    int max_val = -32768;
    long long sum_abs = 0;

    for (int i = 0; i < num_words; i++)
    {
        u32 raw = audio[i];

        int32_t sample24 = SignExtend24(raw);
        int16_t sample16 = (int16_t)(sample24 >> 8);

        if (sample16 < min_val) min_val = sample16;
        if (sample16 > max_val) max_val = sample16;

        int v = sample16;
        if (v < 0) v = -v;
        sum_abs += v;
    }

    xil_printf("\r\nAudio stats with 24-bit sign extension:\r\n");
    xil_printf("min     = %d\r\n", min_val);
    xil_printf("max     = %d\r\n", max_val);
    xil_printf("avg_abs = %d\r\n", (int)(sum_abs / num_words));
}

static void PrintEvenOddDiagnostics(void)
{
    u32 *audio = (u32 *) MEM_BASE_ADDR;
    int num_words = (5 * NR_AUDIO_SAMPLES) / 4;

    xil_printf("\r\nEven/Odd diagnostics using raw >> 8:\r\n");

    for (int parity = 0; parity < 2; parity++)
    {
        int min_val = 32767;
        int max_val = -32768;
        long long sum_abs = 0;
        int count = 0;

        for (int i = parity; i < num_words; i += 2)
        {
            u32 raw = audio[i];

            // Try the version that seemed active
            int16_t sample = (int16_t)(raw >> 8);

            if (sample < min_val) min_val = sample;
            if (sample > max_val) max_val = sample;

            int v = sample;
            if (v < 0) v = -v;
            sum_abs += v;
            count++;
        }

        xil_printf("%s words: min=%d max=%d avg_abs=%d count=%d\r\n",
                   parity == 0 ? "even" : "odd",
                   min_val,
                   max_val,
                   count > 0 ? (int)(sum_abs / count) : 0,
                   count);
    }
}

