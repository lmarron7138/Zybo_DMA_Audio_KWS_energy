static int ConvertDmaAudioToPcm16(const u32 *dma_audio,
                                  int num_words,
                                  int16_t *pcm16,
                                  int max_samples)
{
    int out_count = 0;

    for (int i = 0; i < num_words && out_count < max_samples; i++)
    {
        u32 raw = dma_audio[i];

        /*
         * Audio appears to be signed 24-bit stored in bits [23:0].
         * The upper byte is 0x00, so we must sign-extend manually.
         */
        int32_t sample24 = SignExtend24(raw);

        /*
         * Convert signed 24-bit to signed 16-bit.
         */
        int16_t sample16 = (int16_t)(sample24 >> 8);

        pcm16[out_count++] = sample16;
    }

    return out_count;
}

static void PrintPcmStats(const int16_t *audio, int n)
{
    int min_val = 32767;
    int max_val = -32768;
    long long sum_abs = 0;

    if (n <= 0)
    {
        xil_printf("\r\nPCM stats: no samples\r\n");
        return;
    }

    for (int i = 0; i < n; i++)
    {
        int16_t sample = audio[i];

        if (sample < min_val) min_val = sample;
        if (sample > max_val) max_val = sample;

        int v = sample;
        if (v < 0) v = -v;
        sum_abs += v;
    }

    xil_printf("\r\nPCM stats:\r\n");
    xil_printf("min     = %d\r\n", min_val);
    xil_printf("max     = %d\r\n", max_val);
    xil_printf("avg_abs = %d\r\n", (int)(sum_abs / n));
}

